{
  "title": "Talvo Auth APIs (Sub0)",
  "description": "Recruiter authentication. Production: Sub0. Local fallback: Express /auth/*",
  "basePath": "/auth",
  "endpoints": [
    {
      "method": "POST",
      "path": "/signup",
      "summary": "Create recruiter account",
      "requestBody": {
        "user_name": "string",
        "user_email": "string",
        "user_pass": "string",
        "user_pass_conf": "string",
        "company_name": "string"
      },
      "response": {
        "success": "string",
        "verificationRequired": "boolean",
        "devOtpToken": "string (dev only when SMTP not configured)"
      },
      "expressFallback": "POST /auth/signup"
    },
    {
      "method": "POST",
      "path": "/confirm",
      "summary": "Verify email with OTP token",
      "requestBody": { "token": "string" },
      "expressFallback": "POST /auth/confirm"
    },
    {
      "method": "POST",
      "path": "/login",
      "summary": "Authenticate and issue session",
      "requestBody": { "user_email": "string", "user_pass": "string" },
      "response": { "success": "string", "user": "users object" },
      "expressFallback": "POST /auth/login"
    },
    {
      "method": "GET",
      "path": "/me",
      "summary": "Current authenticated recruiter",
      "response": { "user": "users object" },
      "expressFallback": "GET /auth/me"
    }
  ]
}
