PORT=5000
MONGO_URI=mongodb://localhost:27017/talvo
ACCESS_SECRET=replace-with-a-long-random-secret
REFRESH_SECRET=replace-with-another-long-random-secret

# Gemini / Google AI Studio
GOOGLE_API_KEY=
